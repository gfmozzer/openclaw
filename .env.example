# OpenClaw .env example
#
# Quick start:
# 1) Copy this file to `.env` (for local runs from this repo), OR to `~/.openclaw/.env` (for launchd/systemd daemons).
# 2) Fill only the values you use.
# 3) Keep real secrets out of git.
#
# Env-source precedence for environment variables (highest -> lowest):
# process env, ./.env, ~/.openclaw/.env, then openclaw.json `env` block.
# Existing non-empty process env vars are not overridden by dotenv/config env loading.
# Note: direct config keys (for example `gateway.auth.token` or channel tokens in openclaw.json)
# are resolved separately from env loading and often take precedence over env fallbacks.

# -----------------------------------------------------------------------------
# Gateway auth + paths
# -----------------------------------------------------------------------------
# Recommended if the gateway binds beyond loopback.
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token
# Example generator: openssl rand -hex 32

# Optional alternative auth mode (use token OR password).
# OPENCLAW_GATEWAY_PASSWORD=change-me-to-a-strong-password

# Optional path overrides (defaults shown for reference).
# OPENCLAW_STATE_DIR=~/.openclaw
# OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json
# OPENCLAW_HOME=~

# Optional: import missing keys from your login shell profile.
# OPENCLAW_LOAD_SHELL_ENV=1
# OPENCLAW_SHELL_ENV_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# Enterprise stateless backend
# -----------------------------------------------------------------------------
# Backend mode: in-memory | s3 | prisma
# OPENCLAW_STATELESS_BACKEND=in-memory

# Prisma/PostgreSQL (required for OPENCLAW_STATELESS_BACKEND=prisma)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/openclaw?schema=public
# DIRECT_URL=postgresql://postgres:postgres@localhost:5432/openclaw?schema=public

# S3/MinIO (required for OPENCLAW_STATELESS_BACKEND=s3)
# OPENCLAW_S3_BUCKET=openclaw-memory
# OPENCLAW_S3_REGION=us-east-1
# OPENCLAW_S3_ENDPOINT=http://localhost:9000
# OPENCLAW_S3_FORCE_PATH_STYLE=1
# OPENCLAW_S3_ACCESS_KEY_ID=minioadmin
# OPENCLAW_S3_SECRET_ACCESS_KEY=minioadmin
# OPENCLAW_S3_SESSION_TOKEN=
# OPENCLAW_S3_ROOT_PREFIX=

# Redis distributed runtime (recommended for multi-replica)
# OPENCLAW_REDIS_URL=redis://localhost:6379
# OPENCLAW_REDIS_PREFIX=openclaw
# OPENCLAW_REDIS_TLS=0

# -----------------------------------------------------------------------------
# Model provider API keys (set at least one)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# OPENCLAW_LIVE_OPENAI_KEY=sk-...
# OPENCLAW_LIVE_ANTHROPIC_KEY=sk-ant-...
# OPENCLAW_LIVE_GEMINI_KEY=...
# OPENAI_API_KEY_1=...
# ANTHROPIC_API_KEY_1=...
# GEMINI_API_KEY_1=...
# GOOGLE_API_KEY=...
# OPENAI_API_KEYS=sk-1,sk-2
# ANTHROPIC_API_KEYS=sk-ant-1,sk-ant-2
# GEMINI_API_KEYS=key-1,key-2

# Optional additional providers
# ZAI_API_KEY=...
# AI_GATEWAY_API_KEY=...
# MINIMAX_API_KEY=...
# SYNTHETIC_API_KEY=...

# -----------------------------------------------------------------------------
# Channels (only set what you enable)
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# Optional channel env fallbacks
# MATTERMOST_BOT_TOKEN=...
# MATTERMOST_URL=https://chat.example.com
# ZALO_BOT_TOKEN=...
# OPENCLAW_TWITCH_ACCESS_TOKEN=oauth:...

# -----------------------------------------------------------------------------
# Tools + voice/media (optional)
# -----------------------------------------------------------------------------
# BRAVE_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...
# FIRECRAWL_API_KEY=...

# ELEVENLABS_API_KEY=...
# XI_API_KEY=...  # alias for ElevenLabs
# DEEPGRAM_API_KEY=...

# -----------------------------------------------------------------------------
# Temporal orchestration (enterprise async scheduling)
# -----------------------------------------------------------------------------
# External orchestrator endpoint used by gateway temporal adapter.
# OPENCLAW_TEMPORAL_ORCHESTRATOR_ENDPOINT=http://temporal-orchestrator:8080

# Optional bearer auth from gateway -> orchestrator bridge.
# OPENCLAW_TEMPORAL_ORCHESTRATOR_AUTH_TOKEN=change-me

# Request timeout (ms) for orchestrator calls.
# OPENCLAW_TEMPORAL_ORCHESTRATOR_TIMEOUT_MS=15000

# Team map for scheduler policy (JSON).
# OPENCLAW_TEMPORAL_TEAM_MAP_JSON={"tenant-a":{"supervisor-1":["worker-1","worker-2"]}}

# Required secret used to sign and verify cron.callback payloads (HMAC-SHA256).
# Must be identical between orchestrator callback emitter and gateway.
# OPENCLAW_TEMPORAL_CALLBACK_SECRET=change-me-to-a-long-random-secret

# -----------------------------------------------------------------------------
# Remote skill adapter / tool bus (optional)
# -----------------------------------------------------------------------------
# OPENCLAW_SKILL_ADAPTER_MODE=local
# OPENCLAW_SKILL_TOOLBUS_ENDPOINT=http://toolbus:8081
# OPENCLAW_SKILL_TOOLBUS_KIND=http
# OPENCLAW_SKILL_TOOLBUS_AUTH_TOKEN=change-me
# OPENCLAW_SKILL_TOOLBUS_TIMEOUT_MS=15000
